{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prun",
  "version": "0.1.0",
  "identifier": "sk.tomas.prun",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Prun",
        "width": 920,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "decorations": false,
        "resizable": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
